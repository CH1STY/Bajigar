DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
# Role allowed to run management commands (defaults to Sports_Manager).
MANAGER_ROLE=Sports_Manager
# Optional: channel ID for server-wide notifications
# (tournament created, "predictions closing soon" alerts).
ANNOUNCEMENT_CHANNEL_ID=
# Optional: port for the analytics web dashboard (defaults to 2026).
WEB_PORT=2026
# Optional: tournament selected by default in the dashboard dropdown.
# Accepts a tournament id (e.g. 2) or its name (e.g. "World Cup 2026").
# Leave empty to default to the first tournament.
WEB_DEFAULT_TOURNAMENT=

# Admin lineup upload page (/admin/lineup). Set to true to enable a browser
# UI where an admin can upload Player-Analysis JSON. Disabled by default; when
# disabled the page and its API return 404.
LINEUP_UPLOAD_ENABLED=false
# Password required to upload lineups on that page. Use a strong, secret value.
LINEUP_ADMIN_PASSWORD=
